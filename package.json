{
  "name": "openclaw-skill-viewer",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first OpenClaw skills dashboard for browsing skills, checking readiness, and exploring skill files.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/GanglyPuma22/openclaw-skill-viewer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GanglyPuma22/openclaw-skill-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/GanglyPuma22/openclaw-skill-viewer/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-skills",
    "skill-dashboard",
    "skill-viewer",
    "skills",
    "dashboard",
    "react",
    "express",
    "local-first",
    "developer-tools"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -p tsconfig.server.json && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node server-dist/server/index.js"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.1",
    "mime-types": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.3",
    "simple-git": "^3.35.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.3.2"
  }
}
